# API Groq (obligatoire - https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=600
GROQ_TEMPERATURE=0.8
GROQ_TIMEOUT=60000

# Identite
MY_NAME=Malkym
MY_PHONE=23675835276
MY_COUNTRY=Centrafrique
MY_CITY=Bangui
MY_TIMEZONE=Africa/Bangui
URGENT_PHONE=23675835276

# Assistant
BOT_NAME=MalkymBot
ABSENCE_START=08:00
ABSENCE_END=18:00
DEMO_MODE=false

# Base de donnees et logs
DB_PATH=./conversations.db
LOG_LEVEL=info
LOG_DIR=./logs

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_USER=10
RATE_LIMIT_WINDOW=3600000

# Recherche web
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=wikipedia
WEB_SEARCH_MAX_RESULTS=3
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# Email (SMTP - SendGrid ou Gmail App Password)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=
EMAIL_FROM=

# Dashboard local
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3050
DASHBOARD_TOKEN=

# Synthese vocale (TTS)
TTS_ENABLED=true
TTS_PROVIDER=gtts
TTS_VOICE=fr
TTS_AUTO_REPLY=true
TTS_MAX_CHARS=500
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Media
MEDIA_DOCUMENT_ENABLED=true
MEDIA_TRANSCRIPTION_ENABLED=true
MEDIA_VISION_ENABLED=true
MEDIA_MAX_BYTES=20971520
