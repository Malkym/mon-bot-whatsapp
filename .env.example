# API Groq (obligatoire)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=600
GROQ_TEMPERATURE=0.8
GROQ_TIMEOUT=30000

# Identite de Malkym
MY_NAME=Malkym
MY_PHONE=23675835276
MY_COUNTRY=Centrafrique
MY_CITY=Bangui
MY_TIMEZONE=Africa/Bangui

# Numero alerte urgence
URGENT_PHONE=23675835276

# Assistant
BOT_NAME=MalkymBot
ABSENCE_START=20:00
ABSENCE_END=08:00
DEMO_MODE=false

# Base de donnees et logs
DB_PATH=./conversations.db
LOG_LEVEL=info
LOG_DIR=./logs

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_USER=10
RATE_LIMIT_WINDOW=3600000

# Recherche web optionnelle
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_MAX_RESULTS=3
# Si WEB_SEARCH_PROVIDER=brave:
BRAVE_SEARCH_API_KEY=

# Dashboard local
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3050
DASHBOARD_TOKEN=
